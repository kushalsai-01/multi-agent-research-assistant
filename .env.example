# ── Groq (free & fast — get key at console.groq.com) ──────────────────────────
GROQ_API_KEY=gsk_your-key-here
# Models: llama-3.3-70b-versatile | mixtral-8x7b-32768 | llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.3

# ── Supabase ──────────────────────────────────────────────────────────────────
# Create free project at supabase.com, run docs/supabase_schema.sql
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-anon-key-here

# ── LangSmith ─────────────────────────────────────────────────────────────────
# Sign up free at smith.langchain.com — traces every agent run automatically
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your-key-here
LANGCHAIN_PROJECT=ai-research-assistant
